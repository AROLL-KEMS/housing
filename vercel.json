{
  "version": 2,
  "builds": [
    {
      "src": "immocam/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.12" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "https://your-external-storage.com/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "immocam/wsgi.py"
    }
  ]
}